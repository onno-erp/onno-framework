{
  "personalizations": [
    { "to": [(${json.arr(msg.to)})] }
  ],
  "from": { "email": [(${json.str(msg.from)})] },
  "subject": [(${json.str(msg.subject)})],
  "content": [
    [#th:block th:if="${msg.text != null}"]{ "type": "text/plain", "value": [(${json.str(msg.text)})] },[/th:block]
    { "type": "text/html", "value": [(${json.str(msg.html)})] }
  ]
}
